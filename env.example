# Application Settings
APP_NAME=Anthropic-Bedrock API Proxy
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=False

# API Settings
API_PREFIX=/v1
DOCS_URL=/docs
OPENAPI_URL=/openapi.json
CORS_ORIGINS=*

# AWS Settings
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_ENDPOINT_URL=
DYNAMODB_ENDPOINT_URL=

# DynamoDB Tables
DYNAMODB_API_KEYS_TABLE=anthropic-proxy-api-keys
DYNAMODB_USAGE_TABLE=anthropic-proxy-usage
DYNAMODB_MODEL_MAPPING_TABLE=anthropic-proxy-model-mapping

# Authentication
API_KEY_HEADER=x-api-key
REQUIRE_API_KEY=True
MASTER_API_KEY=sk-master-key-change-this

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Bedrock Prompt Caching (uses cachePoint in requests)
PROMPT_CACHING_ENABLED=True

# Bedrock Service Tier (default, flex, priority, reserved)
# Note: Claude models only support 'default' and 'reserved' (not 'flex')
DEFAULT_SERVICE_TIER=default

# Timeouts
BEDROCK_TIMEOUT=300
DYNAMODB_TIMEOUT=10
STREAMING_TIMEOUT=300

# Bedrock Concurrency Settings
BEDROCK_THREAD_POOL_SIZE=15
BEDROCK_SEMAPHORE_SIZE=15

# Feature Flags
ENABLE_TOOL_USE=True
ENABLE_EXTENDED_THINKING=True
ENABLE_DOCUMENT_SUPPORT=True

# Monitoring
ENABLE_METRICS=True
ENABLE_TRACING=False
SENTRY_DSN=

# ===========================================
# OpenTelemetry Tracing (requires ENABLE_TRACING=True)
# ===========================================
# OTLP exporter endpoint
# Langfuse Cloud: https://us.cloud.langfuse.com/api/public/otel
# Jaeger:         http://localhost:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=https://us.cloud.langfuse.com/api/public/otel

# Export protocol: http/protobuf (default) or grpc
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Authentication headers (format: key1=value1,key2=value2)
# For Langfuse: echo -n "publicKey:secretKey" | base64
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(publicKey:secretKey)>

# Service name shown in tracing backend
# OTEL_SERVICE_NAME=anthropic-bedrock-proxy

# Record prompt/completion content (PII risk, default false)
# OTEL_TRACE_CONTENT=true

# Sampling ratio 0.0-1.0 (default 1.0 = 100%)
# OTEL_TRACE_SAMPLING_RATIO=1.0

# Programmatic Tool Calling (PTC)
ENABLE_PROGRAMMATIC_TOOL_CALLING=true
PTC_SANDBOX_IMAGE=python:3.11-slim
PTC_SESSION_TIMEOUT=270  # 4.5 minutes
PTC_EXECUTION_TIMEOUT=60
PTC_MEMORY_LIMIT=256m
PTC_NETWORK_DISABLED=true

# ===========================================
# Multi-Provider Gateway (all features default OFF)
# ===========================================

# Master switch — enables provider abstraction, routing, key pool, failover
MULTI_PROVIDER_ENABLED=false

# Provider Key encryption secret (REQUIRED when MULTI_PROVIDER_ENABLED=true)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PROVIDER_KEY_ENCRYPTION_SECRET=

# Routing engine
ROUTING_ENABLED=false

# Smart routing (RouteLLM, lazy-loaded only when enabled)
SMART_ROUTING_ENABLED=false
SMART_ROUTING_STRONG_MODEL=claude-sonnet-4-5-20250929
SMART_ROUTING_WEAK_MODEL=claude-haiku-4-5-20251001
SMART_ROUTING_THRESHOLD=0.5

# Failover (enabled by default — switches to backup model when all keys exhausted)
FAILOVER_ENABLED=true

# Cache-aware routing (keeps model sticky when prompt cache is active)
CACHE_AWARE_ROUTING_ENABLED=true

# Context compression
COMPRESSION_ENABLED=false
COMPRESSION_TOOL_RESULT_MAX_CHARS=2000
COMPRESSION_FOLD_AFTER_TURNS=6

# Multi-Provider DynamoDB Tables
DYNAMODB_PROVIDER_KEYS_TABLE=anthropic-proxy-provider-keys
DYNAMODB_ROUTING_RULES_TABLE=anthropic-proxy-routing-rules
DYNAMODB_FAILOVER_CHAINS_TABLE=anthropic-proxy-failover-chains
DYNAMODB_SMART_ROUTING_CONFIG_TABLE=anthropic-proxy-smart-routing-config